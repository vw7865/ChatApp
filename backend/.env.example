# App
NODE_ENV=development
PORT=8080
LOG_LEVEL=info
DATA_DIR=/app/data/sessions

# API key bootstrap (first user)
DEFAULT_USER_EMAIL=owner@example.com
DEFAULT_API_KEY=change-me-super-secret

# Postgres (local / docker-compose). On Railway, use DATABASE_URL from the Postgres service instead.
DATABASE_URL=
# When using DATABASE_URL with TLS (e.g. Railway): "false" skips strict CA verify (default). Set "true" if you use verified certs.
PG_SSL_REJECT_UNAUTHORIZED=false

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=companion_monitor
POSTGRES_USER=companion_user
POSTGRES_PASSWORD=companion_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1 minute

# Optional APNs (for push helper)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_KEY_PATH=
APNS_PRODUCTION=false
